{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PosDbConnection": "Server=pos-db,1433;Database=${POS_DB_NAME:-PosDB};User Id=sa;Password=${POS_DB_PASSWORD:-YourPassword123!};TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "Secret": "${POS_JWT_SECRET:-YourSuperSecretKeyThatIsAtLeast32CharactersLongForHS256Algorithm}",
    "Issuer": "${POS_JWT_ISSUER:-IdentityService}",
    "Audience": "${POS_JWT_AUDIENCE:-IdentityServiceClient}",
    "ExpiryInMinutes": 60
  },
  "Services": {
    "ProductService": {
      "Url": "${POS_PRODUCT_SERVICE_URL:-http://product-api:8080}"
    },
    "InventoryService": {
      "Url": "${POS_INVENTORY_SERVICE_URL:-http://inventory-api:8080}"
    },
    "PromotionService": {
      "Url": "${POS_PROMOTION_SERVICE_URL:-http://promotion-api:8080}"
    }
  },
  "Momo": {
    "PartnerCode": "${POS_MOMO_PARTNER_CODE:-MOMOBKUN20180529}",
    "AccessKey": "${POS_MOMO_ACCESS_KEY:-change-me}",
    "SecretKey": "${POS_MOMO_SECRET_KEY:-change-me}",
    "Endpoint": "${POS_MOMO_ENDPOINT:-https://test-payment.momo.vn/v2/gateway/api/create}",
    "ReturnUrl": "${POS_MOMO_RETURN_URL:-http://13.229.29.52:5006/api/payment/momo/return}",
    "NotifyUrl": "${POS_MOMO_NOTIFY_URL:-http://13.229.29.52:5006/api/payment/momo/notify}",
    "FrontendSuccessUrl": "${POS_FRONTEND_SUCCESS_URL:-https://bhx-mu.vercel.app/cashier/payment-success}",
    "FrontendFailureUrl": "${POS_FRONTEND_FAILURE_URL:-https://bhx-mu.vercel.app/cashier/payment-failure}"
  }
}
